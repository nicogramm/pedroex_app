<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="PedroEX">
<meta name="theme-color" content="#e0e0e5">
<link rel="manifest" href="manifest.json">
<title>Messages — PedroEX</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#e0e0e5;--bg2:#e8e8ed;--shadow-d:#b8b9be;--shadow-l:#ffffff;
  --text:#2a2a2e;--text2:#777;--text3:#aaa;
  --red:#B32533;--green:#16a34a;--orange:#f59e0b;--blue:#2563eb;
  --neu-out:6px 6px 14px var(--shadow-d),-4px -4px 10px var(--shadow-l);
  --neu-in:inset 4px 4px 8px var(--shadow-d),inset -3px -3px 7px var(--shadow-l);
  --neu-sm:4px 4px 8px var(--shadow-d),-3px -3px 7px var(--shadow-l);
  --neu-xs:3px 3px 6px var(--shadow-d),-2px -2px 5px var(--shadow-l);
}
body.dark {
  --bg:#2a2a2f;--bg2:#313137;--shadow-d:#16161a;--shadow-l:#3e3e46;
  --text:#e8e8ec;--text2:#888;--text3:#555;
  --neu-out:5px 5px 12px var(--shadow-d),-3px -3px 9px var(--shadow-l);
  --neu-in:inset 4px 4px 8px var(--shadow-d),inset -3px -3px 7px var(--shadow-l);
  --neu-sm:4px 4px 8px var(--shadow-d),-3px -3px 7px var(--shadow-l);
  --neu-xs:3px 3px 7px var(--shadow-d),-2px -2px 6px var(--shadow-l);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased}
.screen{display:flex;flex-direction:column;height:100dvh;width:100%}

.topbar{background:var(--bg);display:flex;align-items:center;justify-content:space-between;padding:14px 18px;padding-top:calc(env(safe-area-inset-top,0px)+14px);flex-shrink:0;box-shadow:0 3px 10px rgba(0,0,0,0.07)}
body.dark .topbar{box-shadow:0 3px 10px rgba(0,0,0,0.3)}
.tb-left{display:flex;align-items:center;gap:10px}
.tb-back{width:32px;height:32px;border-radius:10px;background:var(--bg);box-shadow:var(--neu-sm);border:none;color:var(--text2);font-size:16px;display:none;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
.tb-back.show{display:flex}
.tb-title-txt{font-size:16px;font-weight:700;color:var(--text)}
.tb-sub{font-size:11px;color:var(--text2)}
.tb-avatar{width:32px;height:32px;border-radius:50%;border:2px solid var(--red);object-fit:cover;box-shadow:var(--neu-xs)}
.tb-new{width:34px;height:34px;border-radius:12px;background:var(--bg);box-shadow:var(--neu-sm);border:none;color:var(--red);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.tb-new:active{box-shadow:var(--neu-in)}

/* ═══ THREAD LIST ═══ */
.thread-list-wrap{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:10px 12px 90px}
.thread-item{display:flex;align-items:center;gap:12px;padding:12px 10px;border-radius:16px;cursor:pointer;transition:background 0.15s}
.thread-item:active{background:var(--bg2)}
.thread-avatar{width:46px;height:46px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;box-shadow:var(--neu-xs)}
.thread-body{flex:1;min-width:0}
.thread-top{display:flex;justify-content:space-between;align-items:baseline;gap:8px}
.thread-name{font-size:14px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.thread-time{font-size:10px;color:var(--text3);flex-shrink:0}
.thread-preview{font-size:12px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px}
.thread-preview.unread{color:var(--text);font-weight:600}
.thread-unread-badge{min-width:18px;height:18px;border-radius:9px;background:var(--red);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 5px;flex-shrink:0}

.empty-hint{text-align:center;padding:60px 24px;color:var(--text3);font-size:13px;line-height:1.7}

/* ═══ CHAT VIEW ═══ */
.chat-wrap{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:14px 14px 10px;display:flex;flex-direction:column;gap:4px}
.day-sep{text-align:center;font-size:10px;font-weight:700;color:var(--text3);letter-spacing:0.5px;text-transform:uppercase;margin:14px 0 8px}

.msg-row{display:flex;align-items:flex-end;gap:8px;max-width:82%}
.msg-row.mine{align-self:flex-end;flex-direction:row-reverse}
.msg-row.theirs{align-self:flex-start}
.msg-av{width:22px;height:22px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;margin-bottom:2px}
.msg-bubble{padding:9px 13px;border-radius:16px;font-size:13.5px;line-height:1.45;word-wrap:break-word;white-space:pre-wrap}
.msg-row.mine .msg-bubble{background:var(--red);color:#fff;border-bottom-right-radius:4px}
.msg-row.theirs .msg-bubble{background:var(--bg2);color:var(--text);box-shadow:var(--neu-xs);border-bottom-left-radius:4px}
.msg-meta{font-size:9px;color:var(--text3);margin-top:3px;padding:0 4px}
.msg-row.mine .msg-meta{text-align:right}
.msg-seen{color:var(--blue);font-weight:600}

/* ═══ COMPOSER ═══ */
.composer{flex-shrink:0;display:flex;align-items:flex-end;gap:10px;padding:10px 14px calc(10px + env(safe-area-inset-bottom,0px));background:var(--bg);box-shadow:0 -3px 14px rgba(0,0,0,0.07)}
body.dark .composer{box-shadow:0 -3px 14px rgba(0,0,0,0.4)}
.composer-input{flex:1;background:var(--bg);border:none;border-radius:20px;box-shadow:var(--neu-in);padding:11px 16px;color:var(--text);font-size:14px;font-family:'Inter',sans-serif;outline:none;resize:none;max-height:100px;line-height:1.4}
.composer-send{width:40px;height:40px;border-radius:50%;background:var(--red);border:none;color:#fff;font-size:16px;flex-shrink:0;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:4px 4px 12px rgba(179,37,51,0.35)}
.composer-send:active{transform:scale(0.94)}
.composer-send:disabled{opacity:0.4}

/* ═══ SHEET (new conversation picker) ═══ */
.sheet-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;align-items:flex-end}
.sheet-overlay.open{display:flex}
.sheet{background:var(--bg);border-radius:28px 28px 0 0;padding:8px 22px calc(28px + env(safe-area-inset-bottom,0px));width:100%;max-height:80dvh;overflow-y:auto;animation:slideUp 0.28s cubic-bezier(0.16,1,0.3,1)}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sheet-handle{width:40px;height:4px;background:var(--text3);border-radius:2px;margin:0 auto 16px;opacity:0.3}
.sheet-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:14px}
.contact-item{display:flex;align-items:center;gap:12px;padding:10px 6px;cursor:pointer;border-radius:14px}
.contact-item:active{background:var(--bg2)}
.contact-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0}
.contact-name{font-size:14px;font-weight:600;color:var(--text)}
.contact-role{font-size:11px;color:var(--text3)}

.loading-wrap{display:flex;align-items:center;justify-content:center;gap:10px;padding:56px;color:var(--text3);font-size:13px}
.spinner{width:20px;height:20px;border:2px solid var(--text3);border-top-color:var(--red);border-radius:50%;animation:spin 0.7s linear infinite;display:inline-block}
@keyframes spin{to{transform:rotate(360deg)}}
.toast{position:fixed;bottom:calc(90px + env(safe-area-inset-bottom,0px));left:50%;transform:translateX(-50%);background:var(--bg);border-radius:14px;box-shadow:var(--neu-out);border-left:3px solid var(--red);padding:13px 22px;font-size:13px;font-weight:500;color:var(--text);z-index:400;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity 0.25s}
.toast.show{opacity:1}
</style>
</head>
<body>

<div class="screen">
  <div class="topbar">
    <div class="tb-left">
      <button class="tb-back" id="tb-back" onclick="closeChat()">‹</button>
      <div>
        <div class="tb-title-txt" id="tb-title">Messages</div>
        <div class="tb-sub" id="tb-sub" style="display:none"></div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px">
      <button class="tb-new" id="tb-new-btn" onclick="openNewConvo()">✎</button>
      <img class="tb-avatar" id="user-avatar" src="" alt="">
    </div>
  </div>

  <!-- THREAD LIST -->
  <div class="thread-list-wrap" id="thread-list-wrap">
    <div class="loading-wrap"><div class="spinner"></div>&nbsp;Loading messages...</div>
  </div>

  <!-- CHAT VIEW (hidden until a thread is opened) -->
  <div class="chat-wrap" id="chat-wrap" style="display:none"></div>
  <div class="composer" id="composer" style="display:none">
    <textarea class="composer-input" id="composer-input" rows="1" placeholder="Type a message…" onkeydown="handleComposerKey(event)" oninput="autoGrow(this)"></textarea>
    <button class="composer-send" id="composer-send" onclick="sendMessage()">➤</button>
  </div>
</div>

<!-- NEW CONVERSATION SHEET -->
<div class="sheet-overlay" id="convo-sheet">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">New Message</div>
    <div id="contact-list"><div class="loading-wrap"><div class="spinner"></div>&nbsp;Loading contacts...</div></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ═══ CONFIG ═══════════════════════════════════════════
const SHEET_ID       = '174cZS7GPowtmwykUd3JccGqxdGSApUKwNLTDPeulb2U';
const TAB_MESSAGES   = 'Messages';
const TAB_EMPLOYEES  = 'Employees';
const BROADCAST_ID   = 'broadcast';
const POLL_LIST_MS   = 10000;   // thread list refresh
const POLL_CHAT_MS   = 4000;    // open-thread refresh

// ═══ STATE ════════════════════════════════════════════
var token       = '';
var myEmail     = '';
var myName      = '';
var isAdmin     = false;
var allMessages = [];   // raw rows from Messages sheet, each: {rowIndex,id,ts,threadId,senderEmail,senderName,text,readBy:[]}
var contacts    = [];   // [{email,name,role}]
var currentThreadId = null;
var currentThreadLabel = '';
var listPollTimer, chatPollTimer;
var lastRenderedMsgCount = 0;

// ═══ INIT ═════════════════════════════════════════════
(function init() {
  document.body.classList.toggle('dark', localStorage.getItem('pedroex-theme') === 'dark');
  token = localStorage.getItem('pedroex-token') || '';
  var expiry = parseInt(localStorage.getItem('pedroex-token-expiry') || '0');
  if (!token || Date.now() >= expiry) { location.href = 'index.html'; return; }

  myEmail = (localStorage.getItem('pedroex-email') || '').toLowerCase();
  myName  = localStorage.getItem('pedroex-firstname') || (localStorage.getItem('pedroex-name') || 'Me');
  isAdmin = (localStorage.getItem('pedroex-role') || '').toLowerCase() === 'admin';

  var pic = localStorage.getItem('pedroex-picture') || '';
  if (pic) document.getElementById('user-avatar').src = pic;

  loadContacts();
  loadMessages(true);

  listPollTimer = setInterval(function() {
    if (!currentThreadId) loadMessages(false);
  }, POLL_LIST_MS);
})();

window.addEventListener('beforeunload', function() {
  clearInterval(listPollTimer);
  clearInterval(chatPollTimer);
});

// ═══ LOAD CONTACTS (Employees sheet) ═══════════════════
function loadContacts() {
  apiGet(TAB_EMPLOYEES + '!A2:D').then(function(res) {
    var rows = res.values || [];
    contacts = rows
      .filter(function(r) { return r[0] && (r[0] || '').toLowerCase() !== myEmail; })
      .map(function(r) {
        return { email: (r[0] || '').toLowerCase(), name: r[1] || r[0], role: r[3] || 'Employee' };
      });
  }).catch(function(e) { console.error('Load contacts error:', e); });
}

// ═══ LOAD MESSAGES ══════════════════════════════════════
function loadMessages(showLoader) {
  if (showLoader) {
    document.getElementById('thread-list-wrap').innerHTML =
      '<div class="loading-wrap"><div class="spinner"></div>&nbsp;Loading messages...</div>';
  }
  apiGet(TAB_MESSAGES + '!A2:G').then(function(res) {
    var rows = res.values || [];
    allMessages = rows.map(function(r, i) {
      return {
        rowIndex:    i + 2,
        id:          r[0] || '',
        ts:          r[1] || '',
        threadId:    r[2] || '',
        senderEmail: (r[3] || '').toLowerCase(),
        senderName:  r[4] || '',
        text:        r[5] || '',
        readBy:      (r[6] || '').split(',').map(function(s){ return s.trim().toLowerCase(); }).filter(Boolean)
      };
    }).filter(function(m){ return m.id && m.threadId; });

    renderThreadList();

    if (currentThreadId) renderChat(currentThreadId, currentThreadLabel);
  }).catch(function(err) {
    console.error('Load messages error:', err);
    if (String(err.message || '').toLowerCase().indexOf('unable to parse range') > -1 ||
        String(err.message || '').toLowerCase().indexOf('not found') > -1) {
      // Messages sheet doesn't exist yet — that's fine, just show empty state
      allMessages = [];
      renderThreadList();
    } else if (showLoader) {
      document.getElementById('thread-list-wrap').innerHTML =
        '<div class="empty-hint">Couldn\'t load messages.<br>Pull down or reopen the page to retry.</div>';
    }
  });
}

// ═══ THREAD LIST RENDER ═════════════════════════════════
function threadsFromMessages() {
  var map = {}; // threadId -> {lastMsg, unread, otherEmail, otherName}
  allMessages.forEach(function(m) {
    if (!map[m.threadId]) map[m.threadId] = { threadId: m.threadId, lastMsg: null, unread: 0 };
    var t = map[m.threadId];
    if (!t.lastMsg || m.ts > t.lastMsg.ts) t.lastMsg = m;
    var isMine = m.senderEmail === myEmail;
    if (!isMine && m.readBy.indexOf(myEmail) === -1) t.unread++;
  });

  var threads = Object.values(map).map(function(t) {
    if (t.threadId === BROADCAST_ID) {
      t.label = '📢 Announcements';
      t.isBroadcast = true;
    } else {
      var parts = t.threadId.split('|');
      var otherEmail = parts.find(function(p){ return p !== myEmail; }) || parts[0];
      var contact = contacts.find(function(c){ return c.email === otherEmail; });
      t.label = contact ? contact.name : (otherEmail || 'Unknown');
      t.otherEmail = otherEmail;
    }
    return t;
  });

  threads.sort(function(a, b) {
    var ta = a.lastMsg ? a.lastMsg.ts : '';
    var tb = b.lastMsg ? b.lastMsg.ts : '';
    return tb.localeCompare(ta);
  });

  return threads;
}

function avatarColor(seed) {
  var colors = ['#B32533','#2563eb','#16a34a','#f59e0b','#7c3aed','#0891b2','#db2777'];
  var h = 0;
  for (var i = 0; i < (seed || '').length; i++) h = (h * 31 + seed.charCodeAt(i)) >>> 0;
  return colors[h % colors.length];
}
function initials(name) {
  if (!name) return '?';
  var parts = name.trim().split(/\s+/);
  return ((parts[0] || '')[0] || '') + ((parts[1] || '')[0] || '');
}

function renderThreadList() {
  var threads = threadsFromMessages();
  var wrap = document.getElementById('thread-list-wrap');

  if (!threads.length) {
    wrap.innerHTML = '<div class="empty-hint">No conversations yet.<br>Tap ✎ above to start messaging someone.</div>';
    return;
  }

  wrap.innerHTML = threads.map(function(t) {
    var preview = t.lastMsg ? (t.lastMsg.senderEmail === myEmail ? 'You: ' : '') + t.lastMsg.text : '';
    var time = t.lastMsg ? fmtTimeShort(t.lastMsg.ts) : '';
    var av = t.isBroadcast
      ? '<div class="thread-avatar" style="background:var(--orange)">📢</div>'
      : '<div class="thread-avatar" style="background:' + avatarColor(t.label) + '">' + initials(t.label) + '</div>';

    return '<div class="thread-item" onclick="openChat(\'' + t.threadId.replace(/'/g,"\\'") + '\',\'' + t.label.replace(/'/g,"\\'") + '\')">'
      + av
      + '<div class="thread-body">'
      + '<div class="thread-top"><div class="thread-name">' + escapeHtml(t.label) + '</div>'
      + '<div class="thread-time">' + time + '</div></div>'
      + '<div class="thread-preview' + (t.unread ? ' unread' : '') + '">' + escapeHtml(preview || 'No messages yet') + '</div>'
      + '</div>'
      + (t.unread ? '<div class="thread-unread-badge">' + t.unread + '</div>' : '')
      + '</div>';
  }).join('');
}

// ═══ OPEN / CLOSE CHAT ══════════════════════════════════
function openChat(threadId, label) {
  currentThreadId = threadId;
  currentThreadLabel = label;
  lastRenderedMsgCount = 0;

  document.getElementById('thread-list-wrap').style.display = 'none';
  document.getElementById('tb-new-btn').style.display = 'none';
  document.getElementById('chat-wrap').style.display = 'flex';
  document.getElementById('composer').style.display = 'flex';
  document.getElementById('tb-back').classList.add('show');
  document.getElementById('tb-title').textContent = label;
  document.getElementById('tb-sub').style.display = '';
  document.getElementById('tb-sub').textContent = threadId === BROADCAST_ID ? 'All employees' : '';

  renderChat(threadId, label);
  markThreadRead(threadId);

  clearInterval(chatPollTimer);
  chatPollTimer = setInterval(function() { loadMessages(false); }, POLL_CHAT_MS);
}

function closeChat() {
  currentThreadId = null;
  clearInterval(chatPollTimer);
  document.getElementById('thread-list-wrap').style.display = '';
  document.getElementById('tb-new-btn').style.display = '';
  document.getElementById('chat-wrap').style.display = 'none';
  document.getElementById('composer').style.display = 'none';
  document.getElementById('tb-back').classList.remove('show');
  document.getElementById('tb-title').textContent = 'Messages';
  document.getElementById('tb-sub').style.display = 'none';
  loadMessages(false);
}

// ═══ RENDER CHAT BUBBLES ════════════════════════════════
function renderChat(threadId, label) {
  var msgs = allMessages.filter(function(m){ return m.threadId === threadId; })
    .sort(function(a,b){ return a.ts.localeCompare(b.ts); });

  if (msgs.length === lastRenderedMsgCount) return; // nothing new — skip re-render/scroll jump
  lastRenderedMsgCount = msgs.length;

  var wrap = document.getElementById('chat-wrap');
  var wasNearBottom = (wrap.scrollHeight - wrap.scrollTop - wrap.clientHeight) < 120;

  if (!msgs.length) {
    wrap.innerHTML = '<div class="empty-hint">Say hi! 👋</div>';
    return;
  }

  var html = '';
  var lastDay = '';
  msgs.forEach(function(m, idx) {
    var day = (m.ts || '').substring(0, 10);
    if (day !== lastDay) {
      html += '<div class="day-sep">' + fmtDayLabel(day) + '</div>';
      lastDay = day;
    }
    var isMine = m.senderEmail === myEmail;
    var showAvatar = !isMine && (idx === msgs.length - 1 || msgs[idx+1].senderEmail !== m.senderEmail);
    var isLastMine = isMine && idx === (function(){
      for (var j = msgs.length - 1; j >= 0; j--) if (msgs[j].senderEmail === myEmail) return j;
      return -1;
    })();

    html += '<div class="msg-row ' + (isMine ? 'mine' : 'theirs') + '">';
    if (!isMine) {
      html += showAvatar
        ? '<div class="msg-av" style="background:' + avatarColor(m.senderName) + '">' + initials(m.senderName) + '</div>'
        : '<div style="width:22px;flex-shrink:0"></div>';
    }
    html += '<div>';
    html += '<div class="msg-bubble">' + escapeHtml(m.text) + '</div>';
    if (isLastMine) {
      var seen = threadId !== BROADCAST_ID
        ? m.readBy.indexOf(otherEmailOf(threadId)) > -1
        : false;
      html += '<div class="msg-meta">' + fmtTimeShort(m.ts) + (seen ? ' · <span class="msg-seen">Seen</span>' : '') + '</div>';
    }
    html += '</div></div>';
  });

  wrap.innerHTML = html;
  if (wasNearBottom || lastRenderedMsgCount <= msgs.length) {
    wrap.scrollTop = wrap.scrollHeight;
  }
}

function otherEmailOf(threadId) {
  if (threadId === BROADCAST_ID) return null;
  var parts = threadId.split('|');
  return parts.find(function(p){ return p !== myEmail; }) || parts[0];
}

// ═══ SEND MESSAGE ═══════════════════════════════════════
function sendMessage() {
  var input = document.getElementById('composer-input');
  var text = input.value.trim();
  if (!text || !currentThreadId) return;

  var id = 'MSG-' + Date.now() + '-' + Math.random().toString(36).slice(2,6);
  var ts = new Date().toISOString();
  var row = [id, ts, currentThreadId, myEmail, myName, text, myEmail];

  // Optimistic local append so it feels instant
  allMessages.push({
    rowIndex: -1, id: id, ts: ts, threadId: currentThreadId,
    senderEmail: myEmail, senderName: myName, text: text, readBy: [myEmail]
  });
  lastRenderedMsgCount = -1; // force re-render
  renderChat(currentThreadId, currentThreadLabel);
  input.value = '';
  autoGrow(input);

  appendMessageRow(row).catch(function(err) {
    console.error('Send failed:', err);
    showToast('❌ Failed to send. Will retry on refresh.');
  });
}

function appendMessageRow(row, isRetry) {
  return apiAppend(TAB_MESSAGES + '!A:G', [row]).catch(function(err) {
    var msg = String(err.message || '').toLowerCase();
    if (!isRetry && (msg.indexOf('unable to parse range') > -1 || msg.indexOf('not found') > -1)) {
      return createMessagesSheet().then(function() { return appendMessageRow(row, true); });
    }
    throw err;
  });
}

function createMessagesSheet() {
  return fetch('https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + ':batchUpdate', {
    method: 'POST',
    headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify({
      requests: [{ addSheet: { properties: { title: TAB_MESSAGES, gridProperties: { rowCount: 2000, columnCount: 7 } } } }]
    })
  }).then(function(r) {
    return r.json().then(function(data) {
      if (!r.ok) {
        var m = (data.error && data.error.message) || '';
        if (m.toLowerCase().indexOf('already exists') === -1) throw new Error('Create Messages sheet failed: ' + m);
      }
      return data;
    });
  }).then(function() {
    return apiUpdate(TAB_MESSAGES + '!A1:G1', [['ID','Timestamp','ThreadID','SenderEmail','SenderName','Message','ReadBy']]);
  });
}

function handleComposerKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}
function autoGrow(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

// ═══ MARK THREAD AS READ ════════════════════════════════
function markThreadRead(threadId) {
  var toMark = allMessages.filter(function(m) {
    return m.threadId === threadId && m.senderEmail !== myEmail && m.readBy.indexOf(myEmail) === -1 && m.rowIndex > 0;
  });
  if (!toMark.length) return;

  var valueRanges = toMark.map(function(m) {
    var newReadBy = m.readBy.concat([myEmail]).join(',');
    m.readBy.push(myEmail); // update local state immediately
    return {
      range: TAB_MESSAGES + '!G' + m.rowIndex,
      values: [[newReadBy]]
    };
  });

  fetch('https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + '/values:batchUpdate', {
    method: 'POST',
    headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify({ valueInputOption: 'USER_ENTERED', data: valueRanges })
  }).then(function() {
    renderThreadList();
  }).catch(function(err) { console.error('Mark read failed:', err); });
}

// ═══ NEW CONVERSATION SHEET ═════════════════════════════
function openNewConvo() {
  var list = document.getElementById('contact-list');
  var items = [];

  if (isAdmin) {
    items.push('<div class="contact-item" onclick="startBroadcast()">'
      + '<div class="contact-avatar" style="background:var(--orange)">📢</div>'
      + '<div><div class="contact-name">Announcements</div><div class="contact-role">Broadcast to all employees</div></div>'
      + '</div>');
  }

  if (!contacts.length) {
    items.push('<div class="empty-hint">No other employees found.</div>');
  } else {
    contacts.forEach(function(c) {
      items.push('<div class="contact-item" onclick="startDM(\'' + c.email.replace(/'/g,"\\'") + '\',\'' + c.name.replace(/'/g,"\\'") + '\')">'
        + '<div class="contact-avatar" style="background:' + avatarColor(c.name) + '">' + initials(c.name) + '</div>'
        + '<div><div class="contact-name">' + escapeHtml(c.name) + '</div><div class="contact-role">' + escapeHtml(c.role) + '</div></div>'
        + '</div>');
    });
  }

  list.innerHTML = items.join('');
  document.getElementById('convo-sheet').classList.add('open');
}

function startDM(email, name) {
  var threadId = [myEmail, email].sort().join('|');
  document.getElementById('convo-sheet').classList.remove('open');
  openChat(threadId, name);
}

function startBroadcast() {
  document.getElementById('convo-sheet').classList.remove('open');
  openChat(BROADCAST_ID, '📢 Announcements');
}

document.getElementById('convo-sheet').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

// ═══ API ══════════════════════════════════════════════
function quoteRange(range) {
  return range.replace(/^([^!]+)(!.*)$/, function(_, sheet, rest) {
    return (sheet.indexOf(' ') >= 0 ? "'" + sheet + "'" : sheet) + rest;
  });
}
function apiGet(range) {
  return fetch('https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + '/values/' + encodeURIComponent(quoteRange(range)),
    { headers: { Authorization: 'Bearer ' + token } })
    .then(function(r) {
      if (r.status === 401) { location.href = 'index.html'; throw new Error('Auth'); }
      if (!r.ok) return r.json().then(function(e){ throw new Error((e.error && e.error.message) || 'Get failed'); });
      return r.json();
    });
}
function apiAppend(range, values) {
  return fetch('https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + '/values/' + encodeURIComponent(quoteRange(range)) + ':append?valueInputOption=USER_ENTERED&insertDataOption=INSERT_ROWS',
    { method: 'POST', headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' }, body: JSON.stringify({ values: values }) })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(e){ throw new Error((e.error && e.error.message) || 'Append failed'); });
      return r.json();
    });
}
function apiUpdate(range, values) {
  return fetch('https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + '/values/' + encodeURIComponent(quoteRange(range)) + '?valueInputOption=USER_ENTERED',
    { method: 'PUT', headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' }, body: JSON.stringify({ values: values }) })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(e){ throw new Error((e.error && e.error.message) || 'Update failed'); });
      return r.json();
    });
}

// ═══ HELPERS ══════════════════════════════════════════
function escapeHtml(s) {
  return String(s || '').replace(/[&<>"']/g, function(c) {
    return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
  });
}
function fmtTimeShort(iso) {
  if (!iso) return '';
  var d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  var today = new Date();
  var isToday = d.toDateString() === today.toDateString();
  if (isToday) return d.toLocaleTimeString('en-PH', { hour:'numeric', minute:'2-digit' });
  return d.toLocaleDateString('en-PH', { month:'short', day:'numeric' });
}
function fmtDayLabel(dayStr) {
  if (!dayStr) return '';
  var d = new Date(dayStr + 'T00:00:00');
  var today = new Date();
  var yest = new Date(today); yest.setDate(yest.getDate() - 1);
  if (d.toDateString() === today.toDateString()) return 'Today';
  if (d.toDateString() === yest.toDateString()) return 'Yesterday';
  return d.toLocaleDateString('en-PH', { weekday:'short', month:'short', day:'numeric', year: d.getFullYear() !== today.getFullYear() ? 'numeric' : undefined });
}

var _tt;
function showToast(m) {
  var t = document.getElementById('toast'); t.textContent = m; t.classList.add('show');
  clearTimeout(_tt); _tt = setTimeout(function(){ t.classList.remove('show'); }, 3500);
}
